<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invitation - SnapSec</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Base styles for email clients */
        body {
            margin: 0;
            padding: 0;
            width: 100% !important;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table {
            border-spacing: 0;
            border-collapse: collapse;
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        td {
            padding: 0;
        }

        img {
            border: 0;
            line-height: 100%;
            outline: none;
            text-decoration: none;
            -ms-interpolation-mode: bicubic;
        }

        /* Mobile specific styles */
        @media screen and (max-width: 520px) {
            .mobile-padding {
                padding-left: 20px !important;
                padding-right: 20px !important;
            }

            .mobile-width {
                width: 100% !important;
                max-width: 100% !important;
            }

            .org-name-text {
                font-size: 24px !important;
            }
        }
    </style>
</head>

<body
    style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">

    <!-- Wrapper Table -->
    <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #f3f4f6; width: 100%;">
        <tr>
            <td align="center" style="padding: 48px 16px;">

                <!-- Main Email Card -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 480px; width: 100%; background-color: #ffffff; border-radius: 24px; border: 1px solid #e5e7eb; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border-collapse: separate;">

                    <!-- Top Accent Bar -->
                    <tr>
                        <td height="6"
                            style="background-color: #1379f0; line-height: 6px; font-size: 6px; border-radius: 24px 24px 0 0;">
                            &nbsp;</td>
                    </tr>

                    <!-- Header Section -->
                    <tr>
                        <td align="center" style="padding: 48px 40px 32px 40px;" class="mobile-padding">
                            <!-- Logo Box -->
                            <table border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td align="center" valign="middle" width="64" height="64"
                                        style="background-color: #f0f7ff; border-radius: 16px;">
                                        <img src="{{logo_url}}" width="40"
                                            alt="SnapSec Logo" style="display: block; border: 0;">
                                    </td>
                                </tr>
                            </table>

                            <h1
                                style="color: #111827; font-size: 24px; font-weight: 700; margin: 24px 0 0 0; letter-spacing: -0.02em; line-height: 1.2;">
                                You're Invited
                            </h1>
                            <p style="color: #4b5563; font-size: 15px; margin: 10px 0 0 0; line-height: 1.5;">
                                {{inviterName}} has invited you to join their organization
                            </p>
                        </td>
                    </tr>

                    <!-- Organization Section -->
                    <tr>
                        <td style="padding: 0 40px 40px 40px;" class="mobile-padding">
                            <!-- Organization Box -->
                            <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                style="border-width: 2px; border-style: solid; border-radius: 15px; border-color:#f9fafb; margin-top: 10px;">
                                <tr>
                                    <td align="center" style="padding: 12px 16px 0 16px;">
                                        <p style="color: #4b5563; font-size: 15px; margin: 0; line-height: 1.5; text-align: center;">
                                            You have been invited to join the Organization:
                                        </p>
                                    </td>
                                </tr>
                                <tr>
                                    <td align="center" style="padding: 24px 16px 32px 16px;">
                                        <span class="org-name-text"
                                            style="color: #1379f0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; font-size: 28px; font-weight: 700;">{{orgName}}</span>
                                    </td>
                                </tr>
                            </table>

                            <!-- Role Info -->
                            <p style="margin: 24px 0 0 0; text-align: center; color: #64748b; font-size: 14px;">
                                You'll be joining as a <strong style="color: #111827;">{{role}}</strong>
                            </p>

                            <!-- Action Info -->
                            <p style="margin: 16px 0 0 0; text-align: center; color: #64748b; font-size: 14px;">
                                Click the button below to accept the invitation and join the team.
                            </p>

                            <!-- Accept Button -->
                            <table width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-top: 24px;">
                                <tr>
                                    <td align="center">
                                        <a href="{{inviteLink}}" style="display: inline-block; background-color: #1379f0; color: #ffffff; padding: 14px 32px; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 15px;">
                                            Accept Invitation
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <!-- Security Alert Box -->
                            <table width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-top: 32px;">
                                <tr>
                                    <td
                                        style="background-color: #fffbeb; border-left: 3px solid #f59e0b; padding: 16px; border-radius: 0 8px 8px 0;">
                                        <p style="color: #92400e; font-size: 13px; line-height: 1.6; margin: 0;">
                                            <strong style="color: #b45309;">Important:</strong> If you didn't expect this invitation,
                                            you can safely ignore this email. No further action is required.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center"
                            style="padding: 40px; background-color: #f9fafb; border-top: 1px solid #f3f4f6;"
                            class="mobile-padding">
                            <p
                                style="color: #64748b; font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">
                                &copy; {{year}} SnapSec Suite. All rights reserved.
                            </p>
                            <p style="color: #94a3b8; font-size: 12px; margin: 4px 0 0 0;">
                                Unified Cybersecurity Products & Solutions
                            </p>

                            <!-- Footer Links -->
                            <table border="0" cellspacing="0" cellpadding="0" style="margin-top: 24px;">
                                <tr>
                                    <td style="padding: 0 12px;">
                                        <a href="{{base_url}}"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Dashboard</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://docs.snapsec.co/"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Help
                                            Center</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://snapsec.co/privacy"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Privacy</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- Bottom Meta Footer -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 480px; width: 100%; margin-top: 24px;">
                    <tr>
                        <td align="center" style="padding: 0 40px 48px 40px;" class="mobile-padding">
                            <p style="color: #94a3b8; font-size: 11px; line-height: 1.6; margin: 0;">
                                You are receiving this email because you were invited to join an organization on SnapSec.
                                Please do not reply to this automated message.
                            </p>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>
    </table>
</body>

</html>
