<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Security Progress Report - SnapSec</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Base styles for email clients */
        body {
            margin: 0;
            padding: 0;
            width: 100% !important;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table {
            border-spacing: 0;
            border-collapse: collapse;
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        td {
            padding: 0;
        }

        img {
            border: 0;
            line-height: 100%;
            outline: none;
            text-decoration: none;
            -ms-interpolation-mode: bicubic;
        }

        /* Mobile specific styles */
        @media screen and (max-width: 520px) {
            .mobile-padding {
                padding-left: 20px !important;
                padding-right: 20px !important;
            }

            .mobile-width {
                width: 100% !important;
                max-width: 100% !important;
            }

            .stat-cell {
                display: block !important;
                width: 100% !important;
                padding: 10px 0 !important;
            }
        }
    </style>
</head>

<body
    style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">

    <!-- Wrapper Table -->
    <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #f3f4f6; width: 100%;">
        <tr>
            <td align="center" style="padding: 48px 16px;">

                <!-- Main Email Card -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 520px; width: 100%; background-color: #ffffff; border-radius: 24px; border: 1px solid #e5e7eb; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border-collapse: separate;">

                    <!-- Top Accent Bar -->
                    <tr>
                        <td height="6"
                            style="background-color: #10b981; line-height: 6px; font-size: 6px; border-radius: 24px 24px 0 0;">
                            &nbsp;</td>
                    </tr>

                    <!-- Header Section -->
                    <tr>
                        <td align="center" style="padding: 48px 40px 32px 40px;" class="mobile-padding">
                            <!-- Logo Box -->
                            <table border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td align="center" valign="middle" width="64" height="64"
                                        style="background-color: #f0f7ff; border-radius: 16px;">
                                        <img src="https://snapsec.co/logos/blue-medium.png" width="40"
                                            alt="SnapSec Logo" style="display: block; border: 0;">
                                    </td>
                                </tr>
                            </table>

                            <h1
                                style="color: #111827; font-size: 22px; font-weight: 700; margin: 24px 0 0 0; letter-spacing: -0.02em; line-height: 1.2;">
                                Security Progress Report
                            </h1>
                            <p style="color: #4b5563; font-size: 15px; margin: 10px 0 0 0; line-height: 1.5;">
                                Periodic overview of vulnerability management.
                            </p>

                            <!-- Team & Department Info -->
                            <table border="0" cellspacing="0" cellpadding="0" style="margin-top: 16px;">
                                <tr>
                                    <td style="background-color: #f0fdf4; border-radius: 8px; padding: 6px 12px;">
                                        <p
                                            style="color: #166534; font-size: 12px; font-weight: 700; margin: 0; text-transform: uppercase; letter-spacing: 0.05em;">
                                            Team: <span style="font-weight: 500;">Core Security</span> &nbsp;•&nbsp;
                                            Dept: <span style="font-weight: 500;">Engineering Ops</span>
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Progress Visualization Section -->
                    <tr>
                        <td style="padding: 0 40px 32px 40px;" class="mobile-padding">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                style="background-color: #f9fafb; border-radius: 20px; padding: 24px;">
                                <tr>
                                    <td colspan="2" style="padding-top: 10px; padding-left: 10px;">
                                        <p
                                            style="margin: 0; color: #64748b; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">
                                            Resolution Rate</p>
                                        <p
                                            style="margin: 6px 0 16px 0; color: #111827; font-size: 20px; font-weight: 800;">
                                            {{stats.resolutionRate}}% Complete</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding-top: 24px;">
                                        <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                            <tr>
                                                <td class="stat-cell" width="33%"
                                                    style="padding-bottom: 10px; padding-left: 10px;">
                                                    <p
                                                        style="margin: 0; color: #111827; font-size: 20px; font-weight: 700;">
                                                        {{stats.resolved}}</p>
                                                    <p
                                                        style="margin: 2px 0 0 0; color: #10b981; font-size: 11px; font-weight: 600;">
                                                        Resolved</p>
                                                </td>
                                                <td class="stat-cell" width="33%" style="padding-left: 10px;">
                                                    <p
                                                        style="margin: 0; color: #111827; font-size: 20px; font-weight: 700;">
                                                        {{stats.pending}}</p>
                                                    <p
                                                        style="margin: 2px 0 0 0; color: #f59e0b; font-size: 11px; font-weight: 600;">
                                                        Pending</p>
                                                </td>
                                                <td class="stat-cell" width="33%" style="padding-left: 10px;">
                                                    <p
                                                        style="margin: 0; color: #111827; font-size: 20px; font-weight: 700;">
                                                        {{stats.newIssues}}</p>
                                                    <p
                                                        style="margin: 2px 0 0 0; color: #3b82f6; font-size: 11px; font-weight: 600;">
                                                        New Issues</p>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Detailed Breakdown -->
                    <tr>
                        <td style="padding: 0 40px 40px 40px;" class="mobile-padding">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td align="center">
                                        <a href="{{base_url}}/reports"
                                            style="background-color: #1379f0; border-radius: 12px; color: #ffffff; display: inline-block; font-size: 15px; font-weight: 600; line-height: 48px; text-align: center; text-decoration: none; width: 100%; box-shadow: 0 4px 12px rgba(19, 121, 240, 0.25);">Download
                                            Detailed PDF Report</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center"
                            style="padding: 40px; background-color: #f9fafb; border-top: 1px solid #f3f4f6;"
                            class="mobile-padding">
                            <p
                                style="color: #64748b; font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">
                                &copy; {{year}} SnapSec Suite. All rights reserved.
                            </p>
                            <p style="color: #94a3b8; font-size: 12px; margin: 4px 0 0 0;">
                                Unified Cybersecurity Products & Solutions
                            </p>

                            <!-- Footer Links -->
                            <table border="0" cellspacing="0" cellpadding="0" style="margin-top: 24px;">
                                <tr>
                                    <td style="padding: 0 12px;">
                                        <a href="{{base_url}}"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Dashboard</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://docs.snapsec.co/"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Help
                                            Center</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://snapsec.co/privacy"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Privacy</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- Bottom Meta Footer -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 520px; width: 100%; margin-top: 24px;">
                    <tr>
                        <td align="center" style="padding: 0 40px 48px 40px;" class="mobile-padding">
                            <p style="color: #94a3b8; font-size: 11px; line-height: 1.6; margin: 0;">
                                This report is intended for team leads and stakeholders. If you believe you received
                                this by mistake, please contact your security administrator.
                            </p>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>
    </table>
</body>

</html>
