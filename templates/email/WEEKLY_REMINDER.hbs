<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weekly Security Reminder - SnapSec</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Base styles for email clients */
        body {
            margin: 0;
            padding: 0;
            width: 100% !important;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table {
            border-spacing: 0;
            border-collapse: collapse;
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        td {
            padding: 0;
        }

        img {
            border: 0;
            line-height: 100%;
            outline: none;
            text-decoration: none;
            -ms-interpolation-mode: bicubic;
        }

        /* Mobile specific styles */
        @media screen and (max-width: 520px) {
            .mobile-padding {
                padding-left: 20px !important;
                padding-right: 20px !important;
            }

            .mobile-width {
                width: 100% !important;
                max-width: 100% !important;
            }

            .stat-cell {
                display: block !important;
                width: 100% !important;
                padding: 10px 0 !important;
            }
        }
    </style>
</head>

<body
    style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">

    <!-- Wrapper Table -->
    <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #f3f4f6; width: 100%;">
        <tr>
            <td align="center" style="padding: 48px 16px;">

                <!-- Main Email Card -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 500px; width: 100%; background-color: #ffffff; border-radius: 24px; border: 1px solid #e5e7eb; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border-collapse: separate;">

                    <!-- Top Accent Bar -->
                    <tr>
                        <td height="6"
                            style="background-color: #1379f0; line-height: 6px; font-size: 6px; border-radius: 24px 24px 0 0;">
                            &nbsp;</td>
                    </tr>

                    <!-- Header Section -->
                    <tr>
                        <td align="center" style="padding: 48px 40px 32px 40px;" class="mobile-padding">
                            <!-- Logo Box -->
                            <table border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td align="center" valign="middle" width="64" height="64"
                                        style="background-color: #f0f7ff; border-radius: 16px;">
                                        <img src="{{logo_url}}" width="40"
                                            alt="SnapSec Logo" style="display: block; border: 0;">
                                    </td>
                                </tr>
                            </table>

                            <h1
                                style="color: #111827; font-size: 22px; font-weight: 700; margin: 24px 0 0 0; letter-spacing: -0.02em; line-height: 1.2;">
                                Weekly Security Digest
                            </h1>
                            <p style="color: #4b5563; font-size: 15px; margin: 10px 0 0 0; line-height: 1.5;">
                                Here is your weekly summary of outstanding tasks.
                            </p>
                        </td>
                    </tr>

                    <!-- Stats Summary Card -->
                    <tr>
                        <td style="padding: 0 40px 32px 40px;" class="mobile-padding">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                style="background-color: #f9fafb; border-radius: 20px;">
                                <tr>
                                    <td align="center" style="padding-top: 20px;">
                                        <p
                                            style="margin: 0; color: #64748b; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">
                                            Total Open Issues</p>
                                        <p
                                            style="margin: 8px 0 0 0; color: #111827; font-size: 48px; font-weight: 800; line-height: 1;">
                                            {{stats.totalOpen}}</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding-bottom: 10px; padding-top: 20px;">
                                        <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                            <tr>
                                                <td class="stat-cell" align="center" width="33%">
                                                    <p
                                                        style="margin: 0; color: #ef4444; font-size: 20px; font-weight: 700;">
                                                        {{stats.critical}}</p>
                                                    <p
                                                        style="margin: 2px 0 0 0; color: #64748b; font-size: 11px; font-weight: 500;">
                                                        Critical</p>
                                                </td>
                                                <td class="stat-cell" align="center" width="33%"
                                                    style="border-left: 1px solid #e2e8f0; border-right: 1px solid #e2e8f0;">
                                                    <p
                                                        style="margin: 0; color: #f97316; font-size: 20px; font-weight: 700;">
                                                        {{stats.high}}</p>
                                                    <p
                                                        style="margin: 2px 0 0 0; color: #64748b; font-size: 11px; font-weight: 500;">
                                                        High</p>
                                                </td>
                                                <td class="stat-cell" align="center" width="33%">
                                                    <p
                                                        style="margin: 0; color: #3b82f6; font-size: 20px; font-weight: 700;">
                                                        {{stats.medium}}</p>
                                                    <p
                                                        style="margin: 2px 0 0 0; color: #64748b; font-size: 11px; font-weight: 500;">
                                                        Medium</p>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- CTA Section -->
                    <tr>
                        <td style="padding: 0 40px 40px 40px;" class="mobile-padding">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td>
                                        <p style="color: #4b5563; font-size: 14px; line-height: 1.6; margin: 0;">
                                            Hello Team,<br><br>
                                            This is a reminder that you have several open vulnerabilities that have not
                                            been addressed yet. Please prioritize the **Critical** and **High** issues
                                            to ensure our platform remains secure and stays within SLA compliance.
                                        </p>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding-top: 32px;" align="center">
                                        <!--[if mso]>
                                        <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{base_url}}/dashboard" style="height:48px;v-text-anchor:middle;width:220px;" arcsize="25%" stroke="f" fillcolor="#1379f0">
                                          <w:anchorlock/>
                                          <center>
                                        <![endif]-->
                                        <a href="{{base_url}}/dashboard"
                                            style="background-color: #1379f0; border-radius: 12px; color: #ffffff; display: inline-block; font-size: 15px; font-weight: 600; line-height: 48px; text-align: center; text-decoration: none; width: 100%; box-shadow: 0 4px 12px rgba(19, 121, 240, 0.25);">Review
                                            Open Tickets</a>
                                        <!--[if mso]>
                                          </center>
                                        </v:roundrect>
                                        <![endif]-->
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center"
                            style="padding: 40px; background-color: #f9fafb; border-top: 1px solid #f3f4f6;"
                            class="mobile-padding">
                            <p
                                style="color: #64748b; font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">
                                &copy; {{year}} SnapSec Suite. All rights reserved.
                            </p>
                            <p style="color: #94a3b8; font-size: 12px; margin: 4px 0 0 0;">
                                Unified Cybersecurity Products & Solutions
                            </p>

                            <!-- Footer Links -->
                            <table border="0" cellspacing="0" cellpadding="0" style="margin-top: 24px;">
                                <tr>
                                    <td style="padding: 0 12px;">
                                        <a href="{{base_url}}"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Dashboard</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://docs.snapsec.co/"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Help
                                            Center</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://snapsec.co/privacy"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Privacy</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- Bottom Meta Footer -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 500px; width: 100%; margin-top: 24px;">
                    <tr>
                        <td align="center" style="padding: 0 40px 48px 40px;" class="mobile-padding">
                            <p style="color: #94a3b8; font-size: 11px; line-height: 1.6; margin: 0;">
                                You are receiving this weekly automated summary as a registered owner of vulnerabilities
                                on SnapSec. You can adjust your notification frequency in your settings.
                            </p>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>
    </table>
</body>

</html>
