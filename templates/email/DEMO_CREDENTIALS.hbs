<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Demo Account Credentials - SnapSec</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Base styles for email clients */
        body {
            margin: 0;
            padding: 0;
            width: 100% !important;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table {
            border-spacing: 0;
            border-collapse: collapse;
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        td {
            padding: 0;
        }

        img {
            border: 0;
            line-height: 100%;
            outline: none;
            text-decoration: none;
            -ms-interpolation-mode: bicubic;
        }

        /* Mobile specific styles */
        @media screen and (max-width: 520px) {
            .mobile-padding {
                padding-left: 20px !important;
                padding-right: 20px !important;
            }

            .mobile-width {
                width: 100% !important;
                max-width: 100% !important;
            }
        }
    </style>
</head>

<body
    style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">

    <!-- Wrapper Table -->
    <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #f3f4f6; width: 100%;">
        <tr>
            <td align="center" style="padding: 48px 16px;">

                <!-- Main Email Card -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 520px; width: 100%; background-color: #ffffff; border-radius: 24px; border: 1px solid #e5e7eb; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border-collapse: separate;">

                    <!-- Top Accent Bar -->
                    <tr>
                        <td height="6"
                            style="background-color: #1379f0; line-height: 6px; font-size: 6px; border-radius: 24px 24px 0 0;">
                            &nbsp;</td>
                    </tr>

                    <!-- Header Section -->
                    <tr>
                        <td align="center" style="padding: 48px 40px 32px 40px;" class="mobile-padding">
                            <!-- Logo Box -->
                            <table border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td align="center" valign="middle" width="64" height="64"
                                        style="background-color: #f0f7ff; border-radius: 16px;">
                                        <img src="{{logo_url}}" width="40"
                                            alt="SnapSec Logo" style="display: block; border: 0;">
                                    </td>
                                </tr>
                            </table>

                            <h1
                                style="color: #111827; font-size: 24px; font-weight: 700; margin: 24px 0 0 0; letter-spacing: -0.02em; line-height: 1.2;">
                                Your Demo Account is Ready
                            </h1>
                            <p style="color: #4b5563; font-size: 15px; margin: 10px 0 0 0; line-height: 1.5;">
                                Welcome to the Future of Security. Use the credentials below to explore SnapSec.
                            </p>
                        </td>
                    </tr>

                    <!-- Credentials Section -->
                    <tr>
                        <td style="padding: 0 40px 40px 40px;" class="mobile-padding">

                            <p style="color: #4b5563; font-size: 14px; line-height: 1.6; margin: 0 0 24px 0;">
                                Hello {{name}},<br><br>
                                We're excited to have you explore SnapSec. Use the credentials below to access our
                                full-featured
                                demo environment.
                            </p>

                            <!-- Credentials Box -->
                            <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                style="background-color: #f9fafb; border-radius: 16px; border: 1px solid #f1f5f9;">
                                <tr>
                                    <td style="padding: 24px;">
                                        <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                            <tr>
                                                <td style="padding-bottom: 16px;">
                                                    <p
                                                        style="margin: 0; font-size: 11px; color: #64748b; text-transform: uppercase; font-weight: 600; letter-spacing: 0.05em;">
                                                        Demo Email</p>
                                                    <p
                                                        style="margin: 4px 0 0 0; font-size: 16px; color: #0f172a; font-weight: 500;">
                                                        {{demo_email}}</p>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="border-top: 1px solid #f1f5f9; padding-top: 16px;">
                                                    <p
                                                        style="margin: 0; font-size: 11px; color: #64748b; text-transform: uppercase; font-weight: 600; letter-spacing: 0.05em;">
                                                        Password</p>
                                                    <p
                                                        style="margin: 4px 0 0 0; font-size: 16px; color: #1379f0; font-weight: 600; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;">
                                                        {{demo_password}}</p>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            <!-- Call to Action -->
                            <table width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-top: 32px;">
                                <tr>
                                    <td align="center">
                                        <a href="{{demo_url}}"
                                            style="background-color: #111827; color: #ffffff; font-weight: 600; text-decoration: none; font-size: 15px; display: inline-block; padding: 16px 40px; border-radius: 12px; box-shadow: 0 4px 12px rgba(17, 24, 39, 0.15);">
                                            Login Here
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <!-- Pro Tip Box -->
                            <table width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-top: 40px;">
                                <tr>
                                    <td
                                        style="background-color: #fffbeb; border-left: 3px solid #f59e0b; padding: 16px; border-radius: 0 8px 8px 0;">
                                        <p style="color: #92400e; font-size: 13px; line-height: 1.6; margin: 0;">
                                            <strong style="color: #b45309;">💡 Pro Tip:</strong> These credentials are
                                            valid for the shared
                                            demo environment. Any data you create may be visible to other demo users.
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center"
                            style="padding: 40px; background-color: #f9fafb; border-top: 1px solid #f3f4f6;"
                            class="mobile-padding">
                            <p
                                style="color: #64748b; font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">
                                &copy; 2026 SnapSec Suite. All rights reserved.
                            </p>
                            <p style="color: #94a3b8; font-size: 12px; margin: 4px 0 0 0;">
                                Unified Cybersecurity Products & Solutions
                            </p>

                            <!-- Footer Links -->
                            <table border="0" cellspacing="0" cellpadding="0" style="margin-top: 24px;">
                                <tr>
                                    <td style="padding: 0 12px;">
                                        <a href="https://demo.snapsec.co"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Demo
                                            Portal</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://docs.snapsec.co/"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Help
                                            Center</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://snapsec.co/privacy"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Privacy</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- Bottom Meta Footer -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 520px; width: 100%; margin-top: 24px;">
                    <tr>
                        <td align="center" style="padding: 0 40px 48px 40px;" class="mobile-padding">
                            <p style="color: #94a3b8; font-size: 11px; line-height: 1.6; margin: 0;">
                                You are receiving this email because a demo account was requested for this email
                                address.
                                Please do not reply to this automated message.
                            </p>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>
    </table>
</body>

</html>
