<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Policy Alert - SnapSec</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            width: 100% !important;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table {
            border-spacing: 0;
            border-collapse: collapse;
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        td {
            padding: 0;
        }

        img {
            border: 0;
            line-height: 100%;
            outline: none;
            text-decoration: none;
            -ms-interpolation-mode: bicubic;
        }

        @media screen and (max-width: 520px) {
            .mobile-padding {
                padding-left: 20px !important;
                padding-right: 20px !important;
            }

            .mobile-width {
                width: 100% !important;
                max-width: 100% !important;
            }

            .stack-column {
                display: block !important;
                width: 100% !important;
                padding: 10px 0 !important;
            }
        }
    </style>
</head>

<body
    style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">

    <!-- Wrapper Table -->
    <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #f3f4f6; width: 100%;">
        <tr>
            <td align="center" style="padding: 48px 16px;">

                <!-- Main Email Card -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 560px; width: 100%; background-color: #ffffff; border-radius: 24px; border: 1px solid #e5e7eb; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border-collapse: separate;">

                    <!-- Top Accent Bar -->
                    <tr>
                        <td height="6"
                            style="background-color: #f59e0b; line-height: 6px; font-size: 6px; border-radius: 24px 24px 0 0;">
                            &nbsp;</td>
                    </tr>

                    <!-- Header Section -->
                    <tr>
                        <td align="center" style="padding: 48px 40px 32px 40px;" class="mobile-padding">
                            <!-- Logo Box -->
                            <table border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td align="center" valign="middle" width="64" height="64"
                                        style="background-color: #fffbeb; border-radius: 16px;">
                                        <img src="{{logo_url}}" width="40"
                                            alt="SnapSec Logo" style="display: block; border: 0;">
                                    </td>
                                </tr>
                            </table>

                            <h1
                                style="color: #111827; font-size: 22px; font-weight: 700; margin: 24px 0 0 0; letter-spacing: -0.02em; line-height: 1.2;">
                                Policy Alert Triggered
                            </h1>
                            <p style="color: #4b5563; font-size: 15px; margin: 10px 0 0 0; line-height: 1.5;">
                                A policy rule matched assets in your inventory.
                            </p>
                        </td>
                    </tr>

                    <!-- Matched Asset Count Banner -->
                    <tr>
                        <td style="padding: 0 40px 32px 40px;" class="mobile-padding">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                style="background-color: #1379f0; border-radius: 16px; padding: 20px;">
                                <tr>
                                    <td align="center" style="padding: 20px;">
                                        <p
                                            style="margin: 0; color: #ffffff; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.9;">
                                            Matched Assets</p>
                                        <p
                                            style="margin: 4px 0 0 0; color: #ffffff; font-size: 36px; font-weight: 800;">
                                            {{matchedAssetCount}}</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Rule Details Section -->
                    <tr>
                        <td style="padding: 0 40px 32px 40px;" class="mobile-padding">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td style="padding-bottom: 16px;">
                                        <p
                                            style="color: #64748b; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 8px 0;">
                                            Rule Details</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                            style="background-color: #f9fafb; border-radius: 12px; padding: 20px;">
                                            <tr>
                                                <td style="padding: 16px;">
                                                    <p style="color: #64748b; font-size: 12px; margin: 0 0 4px 0;">
                                                        Rule Name</p>
                                                    <p
                                                        style="color: #111827; font-size: 16px; font-weight: 700; margin: 0;">
                                                        {{ruleName}}</p>
                                                </td>
                                            </tr>
                                            {{#if ruleDescription}}
                                            <tr>
                                                <td style="padding: 0 16px 16px 16px;">
                                                    <p style="color: #64748b; font-size: 12px; margin: 0 0 4px 0;">
                                                        Description</p>
                                                    <p
                                                        style="color: #374151; font-size: 14px; font-weight: 500; margin: 0; line-height: 1.5;">
                                                        {{ruleDescription}}</p>
                                                </td>
                                            </tr>
                                            {{/if}}
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Matched Assets Table -->
                    <tr>
                        <td style="padding: 0 40px 32px 40px;" class="mobile-padding">
                            <p
                                style="color: #64748b; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 12px 0;">
                                Matched Assets (Preview)</p>
                            <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                style="border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden;">
                                <!-- Table Header -->
                                <tr>
                                    <td
                                        style="padding: 12px 16px; background-color: #f9fafb; border-bottom: 1px solid #e5e7eb; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">
                                        Type</td>
                                    <td
                                        style="padding: 12px 16px; background-color: #f9fafb; border-bottom: 1px solid #e5e7eb; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">
                                        Value</td>
                                    <td
                                        style="padding: 12px 16px; background-color: #f9fafb; border-bottom: 1px solid #e5e7eb; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">
                                        State</td>
                                </tr>
                                <!-- Table Rows -->
                                {{#each assets}}
                                <tr>
                                    <td
                                        style="padding: 10px 16px; border-bottom: 1px solid #f3f4f6; font-size: 13px; color: #111827; font-weight: 500;">
                                        {{this.type}}</td>
                                    <td
                                        style="padding: 10px 16px; border-bottom: 1px solid #f3f4f6; font-size: 13px; color: #374151; max-width: 220px; word-break: break-all;">
                                        {{this.value}}</td>
                                    <td
                                        style="padding: 10px 16px; border-bottom: 1px solid #f3f4f6; font-size: 13px; color: #6b7280;">
                                        {{this.state}}</td>
                                </tr>
                                {{/each}}
                            </table>
                            {{#if hasMoreAssets}}
                            <p style="color: #6b7280; font-size: 13px; margin: 10px 0 0 0; line-height: 1.5;">
                                … and <strong style="color: #111827;">{{remainingAssetCount}}</strong> more assets.
                                The full list is attached as a CSV file.
                            </p>
                            {{/if}}
                        </td>
                    </tr>

                    <!-- CTA Button -->
                    <tr>
                        <td style="padding: 0 40px 40px 40px;" class="mobile-padding">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td align="center">
                                        <!--[if mso]>
                                        <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{action_url}}" style="height:48px;v-text-anchor:middle;width:200px;" arcsize="25%" stroke="f" fillcolor="#1379f0">
                                          <w:anchorlock/>
                                          <center>
                                        <![endif]-->
                                        <a href="{{action_url}}"
                                            style="background-color: #1379f0; border-radius: 12px; color: #ffffff; display: inline-block; font-size: 15px; font-weight: 600; line-height: 48px; text-align: center; text-decoration: none; width: 100%; box-shadow: 0 4px 12px rgba(19, 121, 240, 0.25);">
                                            View in Asset Inventory
                                        </a>
                                        <!--[if mso]>
                                          </center>
                                        </v:roundrect>
                                        <![endif]-->
                                    </td>
                                </tr>
                            </table>

                            <!-- Info Note -->
                            <table width="100%" border="0" cellspacing="0" cellpadding="0" style="margin-top: 32px;">
                                <tr>
                                    <td style="border-top: 1px solid #f1f5f9; padding-top: 24px;">
                                        <p style="color: #4b5563; font-size: 14px; line-height: 1.6; margin: 0;">
                                            This alert was automatically triggered by the policy engine based on your
                                            configured rules. Review the matched assets and take appropriate action if
                                            needed.
                                            {{#if hasAttachment}}
                                            <br><br>
                                            📎 A CSV file containing the complete list of all
                                            <strong>{{matchedAssetCount}}</strong> matched assets is attached to this
                                            email.
                                            {{/if}}
                                        </p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center"
                            style="padding: 40px; background-color: #f9fafb; border-top: 1px solid #f3f4f6;"
                            class="mobile-padding">
                            <p
                                style="color: #64748b; font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">
                                &copy; {{year}} SnapSec Suite. All rights reserved.
                            </p>
                            <p style="color: #94a3b8; font-size: 12px; margin: 4px 0 0 0;">
                                Unified Cybersecurity Products & Solutions
                            </p>

                            <!-- Footer Links -->
                            <table border="0" cellspacing="0" cellpadding="0" style="margin-top: 24px;">
                                <tr>
                                    <td style="padding: 0 12px;">
                                        <a href="{{base_url}}"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Dashboard</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://docs.snapsec.co/"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Help
                                            Center</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://snapsec.co/privacy"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Privacy</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- Bottom Meta Footer -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 560px; width: 100%; margin-top: 24px;">
                    <tr>
                        <td align="center" style="padding: 0 40px 48px 40px;" class="mobile-padding">
                            <p style="color: #94a3b8; font-size: 11px; line-height: 1.6; margin: 0;">
                                This is an automated alert from SnapSec Policy Engine. You can manage your
                                alert policies in the Asset Inventory settings.
                            </p>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>
    </table>
</body>

</html>
