<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SLA Breach Alert - SnapSec</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Base styles for email clients */
        body {
            margin: 0;
            padding: 0;
            width: 100% !important;
            -webkit-text-size-adjust: 100%;
            -ms-text-size-adjust: 100%;
        }

        table {
            border-spacing: 0;
            border-collapse: collapse;
            mso-table-lspace: 0pt;
            mso-table-rspace: 0pt;
        }

        td {
            padding: 0;
        }

        img {
            border: 0;
            line-height: 100%;
            outline: none;
            text-decoration: none;
            -ms-interpolation-mode: bicubic;
        }

        /* Mobile specific styles */
        @media screen and (max-width: 520px) {
            .mobile-padding {
                padding-left: 20px !important;
                padding-right: 20px !important;
            }

            .mobile-width {
                width: 100% !important;
                max-width: 100% !important;
            }

            .stack-column {
                display: block !important;
                width: 100% !important;
                padding: 10px 0 !important;
            }
        }
    </style>
</head>

<body
    style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">

    <!-- Wrapper Table -->
    <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #f3f4f6; width: 100%;">
        <tr>
            <td align="center" style="padding: 48px 16px;">

                <!-- Main Email Card -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 520px; width: 100%; background-color: #ffffff; border-radius: 24px; border: 1px solid #e5e7eb; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border-collapse: separate;">

                    <!-- Top Accent Bar -->
                    <tr>
                        <td height="6"
                            style="background-color: #ef4444; line-height: 6px; font-size: 6px; border-radius: 24px 24px 0 0;">
                            &nbsp;</td>
                    </tr>

                    <!-- Header Section -->
                    <tr>
                        <td align="center" style="padding: 48px 40px 32px 40px;" class="mobile-padding">
                            <!-- Logo Box -->
                            <table border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td align="center" valign="middle" width="64" height="64"
                                        style="background-color: #fef2f2; border-radius: 16px;">
                                        <img src="https://snapsec.co/logos/blue-medium.png" width="40"
                                            alt="SnapSec Logo" style="display: block; border: 0;">
                                    </td>
                                </tr>
                            </table>

                            <h1
                                style="color: #991b1b; font-size: 22px; font-weight: 700; margin: 24px 0 0 0; letter-spacing: -0.02em; line-height: 1.2;">
                                SLA Breach Alert
                            </h1>
                            <p style="color: #4b5563; font-size: 15px; margin: 10px 0 0 0; line-height: 1.5;">
                                Immediate action required: A critical deadline has been missed.
                            </p>
                        </td>
                    </tr>

                    <!-- Overdue Banner Section -->
                    <tr>
                        <td style="padding: 0 40px 32px 40px;" class="mobile-padding">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                style="background-color: #f50f0fb5; border-radius: 16px; padding: 20px;">
                                <tr>
                                    <td align="center" style="padding: 20px">
                                        <p
                                            style="margin: 0; color: #ffffff; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.9;">
                                            Time Overdue</p>
                                        <p
                                            style="margin: 4px 0 0 0; color: #ffffff; font-size: 32px; font-weight: 800;">
                                            {{daysOverdue}} Days</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Details Section -->
                    <tr>
                        <td style="padding: 0 40px 40px 40px;" class="mobile-padding">
                            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                                <tr>
                                    <td style="padding-bottom: 24px;">
                                        <p
                                            style="color: #64748b; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 8px 0;">
                                            Escalation Details</p>
                                        <p
                                            style="color: #111827; font-size: 16px; font-weight: 700; margin: 0; line-height: 1.4;">
                                            {{vuln.title}}</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <table width="100%" border="0" cellspacing="0" cellpadding="0"
                                            style="background-color: #f9fafb; border-radius: 12px; padding: 20px;">
                                            <tr>
                                                <td class="stack-column" width="50%"
                                                    style="padding-bottom: 12px; padding-left: 15px; padding-top: 15px;">
                                                    <p style="color: #64748b; font-size: 12px; margin: 0 0 4px 0;">
                                                        Vulnerability ID</p>
                                                    <p
                                                        style="color: #111827; font-size: 14px; font-weight: 600; margin: 0;">
                                                        {{vuln.orgId}}</p>
                                                </td>
                                                <td class="stack-column" width="50%" style="padding-bottom: 12px;">
                                                    <p style="color: #64748b; font-size: 12px; margin: 0 0 4px 0;">
                                                        Severity</p>
                                                    <p
                                                        style="color: #ef4444; font-size: 14px; font-weight: 700; margin: 0;">
                                                        {{vuln.severity}}</p>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="stack-column" width="50%"
                                                    style="padding-left: 15px; padding-bottom: 15px;">
                                                    <p style="color: #64748b; font-size: 12px; margin: 0 0 4px 0;">SLA
                                                        Deadline</p>
                                                    <p
                                                        style="color: #111827; font-size: 14px; font-weight: 600; margin: 0;">
                                                        {{deadline}}</p>
                                                </td>
                                                <td class="stack-column" width="50%">
                                                    <p style="color: #64748b; font-size: 12px; margin: 0 0 4px 0;">
                                                        Status</p>
                                                    <p
                                                        style="color: #f59e0b; font-size: 14px; font-weight: 600; margin: 0;">
                                                        {{vuln.state}}</p>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding-top: 32px;">
                                        <p style="color: #4b5563; font-size: 14px; line-height: 1.6; margin: 0;">
                                            This notification has been escalated to the <strong>Assignee</strong>,
                                            <strong>Team Lead</strong>, and <strong>Department Head</strong>.
                                            <br><br>
                                            Per security policy, critical vulnerabilities must be resolved within strict
                                            timelines. This ticket has exceeded the allotted timeframe and requires
                                            immediate remediation or an approved exception.
                                        </p>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding-top: 32px;" align="center">
                                        <a href="{{action_url}}"
                                            style="background-color: #111827; border-radius: 12px; color: #ffffff; display: inline-block; font-size: 15px; font-weight: 600; line-height: 48px; text-align: center; text-decoration: none; width: 100%;">Investigate
                                            Immediately</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td align="center"
                            style="padding: 40px; background-color: #f9fafb; border-top: 1px solid #f3f4f6;"
                            class="mobile-padding">
                            <p
                                style="color: #64748b; font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; margin: 0;">
                                &copy; {{year}} SnapSec Suite. All rights reserved.
                            </p>
                            <p style="color: #94a3b8; font-size: 12px; margin: 4px 0 0 0;">
                                Unified Cybersecurity Products & Solutions
                            </p>

                            <!-- Footer Links -->
                            <table border="0" cellspacing="0" cellpadding="0" style="margin-top: 24px;">
                                <tr>
                                    <td style="padding: 0 12px;">
                                        <a href="https://suite.snapsec.co"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Dashboard</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://docs.snapsec.co/"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Help
                                            Center</a>
                                    </td>
                                    <td style="padding: 0 12px;">
                                        <a href="https://snapsec.co/privacy"
                                            style="color: #1379f0; text-decoration: none; font-weight: 600; font-size: 13px;">Privacy</a>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <!-- Bottom Meta Footer -->
                <table width="100%" border="0" cellspacing="0" cellpadding="0" class="mobile-width"
                    style="max-width: 520px; width: 100%; margin-top: 24px;">
                    <tr>
                        <td align="center" style="padding: 0 40px 48px 40px;" class="mobile-padding">
                            <p style="color: #ef4444; font-size: 11px; line-height: 1.6; margin: 0; font-weight: 600;">
                                This is a high-priority escalation. Failure to adhere to SLA policies may result in
                                project blocks or compliance audits.
                            </p>
                        </td>
                    </tr>
                </table>

            </td>
        </tr>
    </table>
</body>

</html>
